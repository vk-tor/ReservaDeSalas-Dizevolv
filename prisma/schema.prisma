// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id           String        @id @default(cuid())
  name         String
  capacity     Int
  reservations Reservation[]
  createdAt    DateTime      @default(now())

  @@map("rooms")
}

model Reservation {
  id           String   @id @default(cuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  title        String
  host         String   @default("Anônimo") // Responsável/Dono da reserva
  participants Int
  startTime    DateTime
  endTime      DateTime
  createdAt    DateTime @default(now())
  seriesId     String?  @map("series_id") // ID de agrupamento para recorrências

  @@index([roomId, startTime, endTime])
  @@map("reservations")
}
